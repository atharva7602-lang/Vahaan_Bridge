# ── DATABASE ──────────────────────────────────────────────
# Get these from your MySQL provider (Railway / PlanetScale / local)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=vahanbridge

# ── SERVER ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────
# Your Netlify frontend URL (set after deploying frontend)
# In development, use: http://localhost:3000 or http://127.0.0.1:5500
FRONTEND_URL=http://localhost:5500

# ── UPLOADS ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
